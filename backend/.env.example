# ── 数据库 ───────────────────────────────────────────────────────────────────
# 本地开发
DATABASE_URL=postgresql+psycopg://postgres:your_password@127.0.0.1:5432/china_university_map

# Supabase（生产）— Project Settings → Database → Connection Pooling → Transaction 模式
# 无需额外 URL 参数；禁用 prepared statement 通过 connect_args 在 database.py 中处理
# DATABASE_URL=postgresql+psycopg://postgres.xxxx:your_password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── 跨域 ─────────────────────────────────────────────────────────────────────
# 逗号分隔，生产环境填写 Vercel 域名（部署后替换）
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# BACKEND_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ── 其他 ─────────────────────────────────────────────────────────────────────
AMAP_API_KEY=

# ── AI 问答 ───────────────────────────────────────────────────────────────────
# Anthropic Console → API Keys
ANTHROPIC_API_KEY=
# DeepSeek Platform → API Keys（https://platform.deepseek.com）
DEEPSEEK_API_KEY=
